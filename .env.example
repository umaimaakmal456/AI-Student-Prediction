# Copy this file to .env for local development.
# In production, add these values in your hosting provider's environment settings.

SECRET_KEY=replace-with-a-random-secret-key

# Local development uses SQLite if DATABASE_URL is not set.
# Production should use your Neon connection string:
# DATABASE_URL=postgresql://user:password@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require
